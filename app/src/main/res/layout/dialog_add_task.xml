<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_white"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="12dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/new_task"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp" />

    <!-- Task title input -->
    <EditText
        android:id="@+id/etTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/add_task_hint"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:background="@android:color/transparent"
        android:maxLines="3"
        android:minLines="2"
        android:paddingBottom="8dp" />


    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="14dp" />

    <!-- Date & Time Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layoutDate"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Date"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTime"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Time"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Category label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- Category Spinner -->
    <Spinner
        android:id="@+id/spinnerAddCategory"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/rounded_card" />

    <!-- Recurrence label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Repeat"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- Recurrence Spinner -->
    <Spinner
        android:id="@+id/spinnerRecurrence"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_card" />

    <!-- Custom Recurrence Layout -->
    <LinearLayout
        android:id="@+id/layoutCustomRecurrence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Every "
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/etCustomDays"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="1"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" days until "
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvCustomEndDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forever"
            android:textColor="@color/ticktick_red"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Priority label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Priority chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <!-- High -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPriorityHigh"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="High"
            android:textSize="12sp"
            app:strokeColor="@color/priority_high"
            app:strokeWidth="1.5dp"
            android:textColor="@color/priority_high" />

        <!-- Medium -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPriorityMed"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Med"
            android:textSize="12sp"
            app:strokeColor="@color/priority_medium"
            app:strokeWidth="1.5dp"
            android:textColor="@color/priority_medium" />

        <!-- Low -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPriorityLow"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Low"
            android:textSize="12sp"
            app:strokeColor="@color/priority_low"
            app:strokeWidth="1.5dp"
            android:textColor="@color/priority_low" />

        <!-- None -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPriorityNone"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="None"
            android:textSize="12sp"
            app:strokeColor="@color/priority_none"
            app:strokeWidth="1.5dp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_task_cancel"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_task_confirm"
            app:backgroundTint="@color/ticktick_red"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>
